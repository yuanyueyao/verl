\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Overview of epistemic token masking.} Using a simple math problem as a example, the figure contrasts naive self-distillation (top) with our masked self-distillation method (bottom). Orange-highlighted tokens denote \colorbox {orange!22}{epistemic tokens} (``Hmm,'' ``Wait,'' ``check''). \textbf  {Top:} Naive self-distillation applies self-distillation signal at every response position, so epistemic-token positions are pushed toward teacher-favored non-epistemic confidential alternatives. Post-distillation, the student loses self-verification and retains the initial mistake. \textbf  {Bottom:} Our masked loss protects epistemic positions while still penalizing errors. Post-distillation, the student retains self-verification and arrives at the correct answer. Training curves on the right summarize the accuracy and output length trends.}}{3}{figure.caption.2}\protected@file@percent }
\newlabel{fig:overview}{{2}{3}{\textbf {Overview of epistemic token masking.} Using a simple math problem as a example, the figure contrasts naive self-distillation (top) with our masked self-distillation method (bottom). Orange-highlighted tokens denote \colorbox {orange!22}{epistemic tokens} (``Hmm,'' ``Wait,'' ``check''). \textbf {Top:} Naive self-distillation applies self-distillation signal at every response position, so epistemic-token positions are pushed toward teacher-favored non-epistemic confidential alternatives. Post-distillation, the student loses self-verification and retains the initial mistake. \textbf {Bottom:} Our masked loss protects epistemic positions while still penalizing errors. Post-distillation, the student retains self-verification and arrives at the correct answer. Training curves on the right summarize the accuracy and output length trends}{figure.caption.2}{}}
